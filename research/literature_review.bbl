      \field{journaltitle}{Ocean Modelling}
      \field{langid}{english}
      \field{month}{1}
      \field{title}{Modelling Landfast Sea Ice and Its Influence on Ocean–Ice Interactions in the Area of the {{Totten Glacier}}, {{East Antarctica}}}
