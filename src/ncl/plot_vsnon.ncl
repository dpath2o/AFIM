begin
    D_graph   = "/g/data/jk72/da1339/GRAPHICAL/CICE/IC/"
    F_ic      = "/scratch/jk72/da1339/cice-dirs/runs/afim_era5/restart/iced.2005-01-01-00000.AOM2_and_NCAR_with_o2i.nc"
    src_file  = addfile(F_ic, "r")
    vsnon_nc0 = src_file->vsnon(0, :, :)
    vsnon_nc0@lat2d = src_file->TLAT
    vsnon_nc0@lon2d = src_file->TLON
    vsnon_nc1 = src_file->vsnon(1, :, :)
    vsnon_nc1@lat2d = src_file->TLAT
    vsnon_nc1@lon2d = src_file->TLON
