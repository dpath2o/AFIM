@article{mechosoAMERICANMONSOONSYSTEMS,
  title = {{{THE AMERICAN MONSOON SYSTEMS}}},
  author = {Mechoso, C Roberto and Robertson, Andrew W and Ropelewski, Chester F and Grimm, Alice M},
  pages = {41},
  abstract = {This paper examines similarities and differences among major features of the North and South American monsoon systems. Over both North and South America the summertime circulation shows upper-level anticyclone/low-level heat low structures. These develop at different distances from the equator. It is argued that ascent to the east where subtropical convergence zones develop, and subsidence over the cool waters of the eastern Pacific where stratocumulus decks provide a radiative heat sink to the tropical atmosphere are integral and unifying aspects of both monsoon systems. The intraseasonal and interannual variability of the systems are contrasted. The reported links between anomalies in soil conditions and sea surface temperatures are marginal, and consistently long-range predictability is low. Ropelewski et al. (2004) and Grimm et al. (2004) focus more closely on each of the American monsoon systems in companion papers.},
  langid = {english},
  keywords = {atmospheric,monsoon},
  file = {/Users/dpath2o/Zotero/storage/WQGVKTJ2/Mechoso et al. - THE AMERICAN MONSOON SYSTEMS.pdf}
}

@article{meijersCirculationWaterMasses2010,
  title = {The Circulation and Water Masses of the {{Antarctic}} Shelf and Continental Slope between 30 and 80{\textsuperscript{\textbackslash circ\$}}{{E}}},
  author = {Meijers, A. J. S. and Klocker, A. and Bindoff, N. L. and Williams, G. D. and Marsland, S. J.},
  year = {2010},
  journal = {Deep Sea Research Part II: Topical Studies in Oceanography},
  volume = {57},
  number = {9},
  pages = {723--737},
  issn = {0967-0645},
  doi = {10.1016/j.dsr2.2009.04.019},
  abstract = {The circulation and water masses from the Antarctic continental shelf to 62\textsuperscript{\textbackslash circ\$}S between 30 and 80\textsuperscript{\textbackslash circ\$}E are described using hydrographic data collected on seven hydrographic sections during the Baseline Research on Oceanography, Krill and the Environment-West (BROKE-West) experiment. The eastern limb of the Weddell Gyre dominates circulation between 30 and 40\textsuperscript{\textbackslash circ\$}E, and is significantly cooler and fresher than the region to the east. The Antarctic Circumpolar Current (ACC) extends from the north into the survey region east of 40\textsuperscript{\textbackslash circ\$}E, reaching as far south as 65.5\textsuperscript{\textbackslash circ\$}S at 60\textsuperscript{\textbackslash circ\$}E. This results in increasing observed maximum temperature and salinities progressively towards the east, peaking at 80\textsuperscript{\textbackslash circ\$}E due to the intrusion of the southern ACC Front (sACCF) to 63\textsuperscript{\textbackslash circ\$}S. This southward extension is steered by the southern end of Kerguelen Plateau, causing a horizontal shear of over 0.15ms-1 between the eastward ACC and westward-flowing Antarctic Slope Current (ASC). The ASC is observed at all six meridional sections immediately north of the shelf break. It is strongly barotropic and transports a total of 15.8\textsuperscript{\textbackslash circ\$}E a `V' shape is observed in the ASF. This, and the nearby presence of denser shelf water and ice-shelf water, is characteristic of Antarctic Bottom Water (AABW) formation, but no new AABW is found on this section. Instead, significantly warmer, saltier and less oxygenated AABW to the east and newly formed AABW high on the continental slope immediately to the west suggest a formation region just west of 70\textsuperscript{\textbackslash circ\$}E. This newly formed AABW progressively becomes warmer and saltier west of 60\textsuperscript{\textbackslash circ\$}E and is observed extending offshore and moving westward below eastward flowing water masses. ACC frontal positions are found to be 1\textendash 2farther north in the survey region than suggested by historical climatology.},
  keywords = {AABW,Boundary current,LADCP,Ocean circulation,Slope front},
  file = {/Users/dpath2o/Zotero/storage/CFDAX5CR/Meijers et al. - 2010 - The circulation and water masses of the Antarctic .pdf}
}

