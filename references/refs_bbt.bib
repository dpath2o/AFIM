  author = {Kiss, Andrew E. and Hogg, Andrew McC and Hannah, Nicholas and Boeira Dias, Fabio and Brassington, Gary B. and Chamberlain, Matthew A. and Chapman, Christopher and Dobrohotoff, Peter and Domingues, Catia M. and Duran, Earl R. and England, Matthew H. and Fiedler, Russell and Griffies, Stephen M. and Heerdegen, Aidan and Heil, Petra and Holmes, Ryan M. and Klocker, Andreas and Marsland, Simon J. and Morrison, Adele K. and Munroe, James and Nikurashin, Maxim and Oke, Peter R. and Pilo, Gabriela S. and Richet, Oc{\'e}ane and Savita, Abhishek and Spence, Paul and Stewart, Kial D. and Ward, Marshall L. and Wu, Fanghua and Zhang, Xihan},
