@article{ohshimaAntarcticBottomWater2013,
  title = {Antarctic {{Bottom Water}} Production by Intense Sea-Ice Formation in the {{Cape Darnley Polynya}}},
  author = {Ohshima, Kay I. and Fukamachi, Yasushi and Williams, Guy D. and Nihashi, Sohey and Roquet, Fabien and Kitade, Yujiro and Tamura, Takeshi and Hirano, Daisuke and {Herraiz-Borreguero}, Laura and Field, Iain and Hindell, Mark and Aoki, Shigeru and Wakatsuchi, Masaaki},
  year = {2013},
  month = mar,
  journal = {Nature Geoscience},
  volume = {6},
  number = {3},
  pages = {235--240},
  abstract = {The formation of Antarctic Bottom Water\textemdash the cold, dense water that occupies the abyssal layer of the global ocean\textemdash is a key process in global ocean circulation. This water mass is formed as dense shelf water sinks to depth. Three regions around Antarctica where this process takes place have been previously documented. The presence of another source has been identified in hydrographic and tracer data, although the site of formation is not well constrained. Here we document the formation of dense shelf water in the Cape Darnley polynya (65\textdegree\textendash 69\textdegree\th inspaceE) and its subsequent transformation into bottom water using data from moorings and instrumented elephant seals (Mirounga leonina). Unlike the previously identified sources of Antarctic Bottom Water, which require the presence of an ice shelf or a large storage volume, bottom water production at the Cape Darnley polynya is driven primarily by the flux of salt released by sea-ice formation. We estimate that about 0.3\textendash 0.7\texttimes 106\th inspacem3\th inspaces-1 of dense shelf water produced by the Cape Darnley polynya is transformed into Antarctic Bottom Water. The transformation of this water mass, which we term Cape Darnley Bottom Water, accounts for 6\textendash 13\% of the circumpolar total.},
  file = {/Users/dpath2o/Zotero/storage/GNDVCLZT/Ohshima et al. - 2013 - Antarctic Bottom Water production by intense sea-i.pdf}
}

@article{ohshimaGlobalViewSeaice2016,
  title = {Global View of Sea-Ice Production in Polynyas and Its Linkage to Dense/Bottom Water Formation},
  author = {Ohshima, Kay I. and Nihashi, Sohey and Iwamoto, Katsushi},
  year = {2016},
  journal = {Geoscience Letters},
  volume = {3},
  number = {1},
  pages = {13},
  doi = {10.1186/s40562-016-0045-4},
  abstract = {Global overturning circulation is driven by density differences. Saline water rejected during sea-ice formation in polynyas is the main source of dense water, and thus sea-ice production is a key factor in the overturning circulation. Due to difficulties associated with in situ observation, sea-ice production and its interannual variability have not been well understood until recently. Methods to estimate sea-ice production on large scales have been developed using heat flux calculations based on satellite microwave radiometer data. Using these methods, we present the mapping of sea-ice production with the same definition and scale globally, and review the polynya ice production and its relationship with dense/bottom water. The mapping demonstrates that ice production rate is high in Antarctic coastal polynyas, in contrast to Arctic coastal polynyas. This is consistent with the formation of Antarctic Bottom Water (AABW), the densest water mass which occupies the abyssal layer of the global ocean. The Ross Ice Shelf polynya has by far the highest ice production in the Southern Hemisphere. The Cape Darnley polynya (65\textsuperscript{\textbackslash circ\$}E\textendash 69\textsuperscript{\textbackslash circ\$}E) is found to be the second highest production area and recent observations revealed that this is the missing (fourth) source of AABW. In the region off the Mertz Glacier Tongue (MGT), the third source of AABW, sea-ice production decreased by as much as 40 \%, due to the MGT calving in early 2010, resulting in a significant decrease in AABW production. The Okhotsk Northwestern polynya exhibits the highest ice production in the Northern Hemisphere, and the resultant dense water formation leads to overturning in the North Pacific, extending to the intermediate layer. Estimates of its ice production show a significant decrease over the past 30\textendash 50 years, likely causing the weakening of the North Pacific overturning. These regions demonstrate the strong linkage between variabilities of sea-ice production and bottom/intermediate water formation. The mapping has also provided surface boundary conditions and validation data of heat- and salt-flux associated with sea-ice formation/melting for various ocean and coupled models.},
  isbn = {2196-4092},
  file = {/Users/dpath2o/Zotero/storage/IEZYHYTV/Ohshima et al. - 2016 - Global view of sea-ice production in polynyas and .pdf}
}

