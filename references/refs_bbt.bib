@article{jourdainOceanCirculationSeaice2017,
  title = {Ocean Circulation and Sea-Ice Thinning Induced by Melting Ice Shelves in the {{Amundsen Sea}}},
  author = {Jourdain, Nicolas C. and Mathiot, Pierre and Merino, Nacho and Durand, Ga{\"e}l and Le Sommer, Julien and Spence, Paul and Dutrieux, Pierre and Madec, Gurvan},
  year = {2017},
  journal = {Journal of Geophysical Research: Oceans},
  volume = {122},
  number = {3},
  pages = {2550--2573},
  doi = {10.1002/2016JC012509},
  abstract = {Abstract A 1/12 ocean model configuration of the Amundsen Sea sector is developed to better understand the circulation induced by ice-shelf melt and the impacts on the surrounding ocean and sea ice. Eighteen sensitivity experiments to drag and heat exchange coefficients at the ice shelf/ocean interface are performed. The total melt rate simulated in each cavity is function of the thermal Stanton number, and for a given thermal Stanton number, melt is slightly higher for lower values of the drag coefficient. Sub-ice-shelf melt induces a thermohaline circulation that pumps warm circumpolar deep water into the cavity. The related volume flux into a cavity is 100\textendash 500 times stronger than the melt volume flux itself. Ice-shelf melt also induces a coastal barotropic current that contributes 45 \$\textbackslash pm\$ 12\% of the total simulated coastal transport. Due to the presence of warm circumpolar deep waters, the melt-induced inflow typically brings 4\textendash 20 times more heat into the cavities than the latent heat required for melt. For currently observed melt rates, approximately 6\textendash 31\% of the heat that enters a cavity with melting potential is actually used to melt ice shelves. For increasing sub-ice-shelf melt rates, the transport in the cavity becomes stronger, and more heat is pumped from the deep layers to the upper part of the cavity then advected toward the ocean surface in front of the ice shelf. Therefore, more ice-shelf melt induces less sea-ice volume near the ice sheet margins.},
  keywords = {Amundsen Sea,circumpolar deep water,efficiency,ice shelf,ocean circulation,sea ice},
  annotation = {\_eprint: https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1002/2016JC012509},
  file = {/Users/dpath2o/Zotero/storage/PYR5535G/Jourdain et al. - 2017 - Ocean circulation and sea-ice thinning induced by .pdf}
}

