@article{aokiCyclonicCirculationAustralian2010,
  title = {The Cyclonic Circulation in the {{Australian}}\textendash{{Antarctic}} Basin Simulated by an Eddy-Resolving General Circulation Model},
  author = {Aoki, Shigeru and Sasai, Yoshikazu and Sasaki, Hideharu and Mitsudera, Humio and Williams, Guy D.},
  year = {2010},
  journal = {Ocean Dynamics},
  volume = {60},
  number = {3},
  pages = {743--757},
  doi = {10.1007/s10236-009-0261-y},
  abstract = {Flow structure in the Australian\textendash Antarctic basin is investigated using an eddy-resolving general ocean circulation model and validated with iceberg and middepth float trajectories. A cyclonic circulation system between the Antarctic Circumpolar Current and Antarctic Slope Current consists of a large-scale gyre in the west (80\textendash 110\textsuperscript{\textbackslash circ\$}E) and a series of eddies in the east (120\textendash 150\textsuperscript{\textbackslash circ\$}E). The western gyre has an annual mean westward transport of 22 Sv in the southern limb. Extending west through the Princess Elizabeth Trough, 5 Sv of the gyre recirculates off Prydz Bay and joins the western boundary current off the Kerguelen Plateau. Iceberg trajectories from QuickScat and ERS-1/2 support this recirculation and the overall structure of the Antarctic Slope Current against isobath in the model. Argo float trajectories also reveal a consistent structure of the deep westward slope current. This study indicates the presence of a large cyclonic circulation in this basin, which is comparable to the Weddell and Ross gyres.},
  isbn = {1616-7228},
  file = {/Users/dpath2o/Zotero/storage/S9VAR4K4/Aoki et al. - 2010 - The cyclonic circulation in the Australian–Antarct.pdf}
}

@article{aokiFresheningAntarcticBottom2020,
  title = {Freshening of {{Antarctic Bottom Water Off Cape Darnley}}, {{East Antarctica}}},
  author = {Aoki, S. and Katsumata, K. and Hamaguchi, M. and Noda, A. and Kitade, Y. and Shimada, K. and Hirano, D. and Simizu, D. and Aoyama, Y. and Doi, K. and Nogi, Y.},
  year = {2020},
  journal = {Journal of Geophysical Research: Oceans},
  volume = {125},
  number = {8},
  pages = {e2020JC016374},
  doi = {10.1029/2020JC016374},
  abstract = {Abstract Recently, a source of Antarctic Bottom Water (AABW) was identified off Cape Darnley at the eastern end of the Weddell-Enderby Basin. However, the behavior and long-term variability of Cape Darnley Bottom Water (CDBW) are not clearly understood. Hydrographic observations from 1974 to 2016 were compared, and a decade-long bottom temperature record was analyzed to clarify multidecadal changes in the CDBW in this region and its downstream influences. In the Cooperation Sea, CDBW spread northwestward with its deepest part reaching to approximately 4,900 dbar. CDBW freshening of 0.001\textendash 0.003 decade-1 was revealed. In the Cosmonaut Sea, long-term AABW warming of approximately 0.01\textendash 0.03\textsuperscript{\textbackslash circ\$}C decade-1 was prominent in the deep basin, while freshening was detected on the upper continental slope. Spatial patterns suggest that an interbasin deep transport of excess freshwater is carried by CDBW and fed into the Weddell Gyre, which might act as an abyssal freshwater buffer.},
  keywords = {Antarctic Bottom Water,Cape Darnley,East Antarctica,freshening,polynya,Weddell Gyre},
  annotation = {\_eprint: https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/2020JC016374}
}

