@article{spenceRapidSubsurfaceWarming2014,
  title = {Rapid Subsurface Warming and Circulation Changes of {{Antarctic}} Coastal Waters by Poleward Shifting Winds},
  author = {Spence, Paul and Griffies, Stephen M. and England, Matthew H. and Hogg, Andrew McC. and Saenko, Oleg A. and Jourdain, Nicolas C.},
  year = {2014},
  journal = {Geophysical Research Letters},
  volume = {41},
  number = {13},
  pages = {4601--4610},
  issn = {1944-8007},
  doi = {10.1002/2014GL060613},
  abstract = {The southern hemisphere westerly winds have been strengthening and shifting poleward since the 1950s. This wind trend is projected to persist under continued anthropogenic forcing, but the impact of the changing winds on Antarctic coastal heat distribution remains poorly understood. Here we show that a poleward wind shift at the latitudes of the Antarctic Peninsula can produce an intense warming of subsurface coastal waters that exceeds 2\textdegree C at 200\textendash 700 m depth. The model simulated warming results from a rapid advective heat flux induced by weakened near-shore Ekman pumping and is associated with weakened coastal currents. This analysis shows that anthropogenically induced wind changes can dramatically increase the temperature of ocean water at ice sheet grounding lines and at the base of floating ice shelves around Antarctica, with potentially significant ramifications for global sea level rise.},
  langid = {english},
  keywords = {Antarctic Coast,coastal currents,Southern Ocean,warming,winds},
  annotation = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/2014GL060613},
  file = {/Users/dpath2o/Zotero/storage/FVQY3CNW/Spence et al. - 2014 - Rapid subsurface warming and circulation changes o.pdf;/Users/dpath2o/Zotero/storage/NMTFWNYC/2014GL060613.html}
}

