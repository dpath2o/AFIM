	journal = {Geophysical Research Letters},
	keywords = {bathymetry, seafloor, IBCSO, IBCAO},
	number = {12},
	pages = {3111-3117},
	title = {The {I}nternational {B}athymetric {C}hart of the {S}outhern {O}cean ({IBCSO}) Version 1.0---A new bathymetric compilation covering circum-{A}ntarctic waters},
