	journal = {Geophysical Research Letters},
	keywords = {{AABW}, {N}orth {A}tlantic {D}eep {W}ater, meridional overturning circulation, ocean circulation},
	number = {15},
	pages = {2923-2926},
	title = {Cooling and ventilating the Abyssal Ocean},
