	doi = {10.3402/polar.v30i0.7124},
	journal = {Polar Research},
	journal1 = {POLAR},
	keywords = {sea ice, model, satellite, ICESat},
	month = {2021/08/06},
	number = {0},
	se = {Thematic cluster. {C}limate drivers of the North: the {L}aptev {S}ea System},
	title = {Evaluation of simulated sea-ice concentrations from sea-ice/ ocean models using satellite data and polynya classification methods},
	ty = {JOUR},
	url = {https://polarresearch.net/index.php/polar/article/view/3066},
	volume = {0},
	year = {2011},
	Bdsk-Url-1 = {https://polarresearch.net/index.php/polar/article/view/3066},
