	journal = {Journal of Geophysical Research: Oceans},
	keywords = {Antarctic Bottom Water, North Atlantic Deep Water, deep ocean ventilation},
	number = {C5},
	title = {Quantifying {A}ntarctic {B}ottom {W}ater and {N}orth {A}tlantic {D}eep {W}ater volumes},
	url = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/2007JC004477},
