	journal = {Journal of Geophysical Research: Oceans},
	number = {C6},
	pages = {9461-9479},
	title = {Polynyas and leads: An overview of physical processes and environment},
	url = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/JC095iC06p09461},
